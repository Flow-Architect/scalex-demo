# ScaleX local demo environment template.
# Copy to .env for local use. Never commit .env.

APP_ENV=development
SCALEX_EXECUTION_MODE=demo
BACKEND_PORT=8790
FRONTEND_PORT=5174
DATABASE_PATH=./data/scalex.db
DATABASE_URL=sqlite:///./data/scalex.db
VITE_API_BASE_URL=http://127.0.0.1:8790

# Local prototype auth. Disabled by default for Judge Demo Mode.
SCALEX_AUTH_ENABLED=false
SCALEX_DEMO_USERNAME=admin
SCALEX_DEMO_PASSWORD=change-me
SCALEX_SESSION_SECRET=change-me

# Judge Demo Mode planning. Deterministic/local proof is the safe default.
HERMES_RUNTIME=isolated_cli
HERMES_MODE=isolated_cli
HERMES_MODEL=
HERMES_PROVIDER=
HERMES_CLI_PATH=
HERMES_HOME=
HERMES_API_BASE_URL=
HERMES_API_KEY=
HERMES_REQUIRE_REAL=false
HERMES_TEST_MODE=true
HERMES_TIMEOUT_SECONDS=60
HERMES_MAX_OUTPUT_CHARS=12000
HERMES_SKILL_NAME=scalex-operator
HERMES_SKILL_SOURCE_PATH=./hermes/skills/scalex-operator
HERMES_TOOLSETS=skills

# Optional NemoClaw/NemoHermes planning route. Leave blank unless configured locally.
NEMOCLAW_BASE_URL=
NEMOCLAW_API_KEY=
NEMOCLAW_SANDBOX_NAME=
NEMOCLAW_PROVIDER=
NEMOCLAW_MODEL=

# Stripe sandbox/test finance. Do not use live keys.
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_TEST_MODE=true
STRIPE_TEST_DOUBLE_MODE=true
STRIPE_LIVE_MODE=false
STRIPE_CURRENCY=usd
STRIPE_IDEMPOTENCY_PREFIX=scalex-demo
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Verified Live Mode is future-only and disabled.
ENABLE_LIVE_PROOF=false
VERIFIED_LIVE_MODE=false
STRIPE_LIVE_MONEY_ENABLED=false
STRIPE_LIVE_REQUIRE_VERIFIED=true
SCALEX_LIVE_MAX_AMOUNT_CENTS=0
SCALEX_LIVE_ALLOWED_CUSTOMER_EMAILS=
SCALEX_LIVE_CONFIRMATION_PHRASE=LIVE_MONEY_APPROVED

# Guardrails / policy. Local policy is the safe default.
POLICY_ENGINE=local
SCALEX_GUARDRAIL_MODE=local_policy
GUARDRAIL_ENGINE=local_policy
GUARDRAILS_FAIL_CLOSED=true
GUARDRAILS_RECORD_EVALUATIONS=true
GUARDRAILS_PROBE_TIMEOUT_SECONDS=15

# Optional NeMo Guardrails adapter verification. Leave blank unless configured locally.
SCALEX_NEMO_PYTHON=
SCALEX_NEMO_CONFIG_PATH=./guardrails/scalex
NEMO_GUARDRAILS_PYTHON=
NEMO_GUARDRAILS_CONFIG_PATH=./guardrails/scalex
NEMO_GUARDRAILS_SERVER_URL=
NEMO_GUARDRAILS_API_KEY=

# Demo economics.
DEFAULT_INVOICE_AMOUNT_USD=8500
DEFAULT_SPEND_CAP_USD=1150
DEFAULT_MARGIN_FLOOR_PERCENT=50
REQUIRE_HUMAN_APPROVAL_ABOVE_USD=1000

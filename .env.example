# ScaleX ClientOps Autopilot Product Prototype
APP_ENV=development
SCALEX_EXECUTION_MODE=demo
BACKEND_PORT=8787
FRONTEND_PORT=5174
DATABASE_PATH=./data/scalex.db

# Judge Demo Mode is the safe default. It works without secrets by using deterministic local
# planning proof, Stripe test-double/sandbox finance proof, local policy, and SQLite evidence.

# Legacy direct-reasoning compatibility. Keep blank for judge checkout.
MODEL_PROVIDER=openai
SCALEX_REASONING_MODEL=
OPENAI_API_KEY=
AI_FALLBACK_MODE=true

# Judge Demo Mode planning. Full Proof Mode values are optional below.
HERMES_MODE=isolated_cli
HERMES_CLI_PATH=
HERMES_HOME=
HERMES_MODEL=gpt-5.5
HERMES_PROVIDER=openai-codex
HERMES_TIMEOUT_SECONDS=60
HERMES_REQUIRE_REAL=false
HERMES_TEST_MODE=true
HERMES_MAX_OUTPUT_CHARS=12000
HERMES_SKILL_NAME=scalex-operator
HERMES_SKILL_SOURCE_PATH=./hermes/skills/scalex-operator
HERMES_TOOLSETS=skills

# Judge Demo Mode finance proof. This does not call Stripe.
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_TEST_MODE=true
STRIPE_LIVE_MODE=false
STRIPE_TEST_DOUBLE_MODE=true
STRIPE_CURRENCY=usd
STRIPE_IDEMPOTENCY_PREFIX=scalex-demo
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_WEBHOOK_SECRET=

# Local prototype auth is disabled by default for judge checkout. To test login locally, set
# SCALEX_AUTH_ENABLED=true and provide local-only values in ignored .env.
SCALEX_AUTH_ENABLED=false
SCALEX_DEMO_USERNAME=
SCALEX_DEMO_PASSWORD=
SCALEX_SESSION_SECRET=

# Optional Full Proof Mode, local only. Uncomment in ignored .env only when safe local real-tool
# configuration exists. Never use live Stripe keys.
# SCALEX_EXECUTION_MODE=full_proof
# HERMES_CLI_PATH=/home/ascabrya/.scalex-hermes/hermes-agent/venv/bin/hermes
# HERMES_HOME=/home/ascabrya/.scalex-hermes/home
# HERMES_REQUIRE_REAL=true
# HERMES_TEST_MODE=false
# STRIPE_TEST_DOUBLE_MODE=false
# Add a Stripe test secret key locally only if needed; do not commit it.

# Future Verified Live Mode placeholders only.
# Current product mode does not execute live-money charges.
STRIPE_LIVE_MONEY_ENABLED=false
STRIPE_LIVE_REQUIRE_VERIFIED=true
SCALEX_LIVE_MAX_AMOUNT_CENTS=0
SCALEX_LIVE_ALLOWED_CUSTOMER_EMAILS=
SCALEX_LIVE_CONFIRMATION_PHRASE=LIVE_MONEY_APPROVED

# Guardrails / policy.
# Current product path uses local policy. Goal 8 plans NVIDIA NeMo Guardrails
# or a NeMo-compatible adapter only if safely available and verified.
POLICY_ENGINE=local
NEMOCLAW_BASE_URL=
NEMOCLAW_API_KEY=
GUARDRAIL_ENGINE=local_policy
NEMO_GUARDRAILS_CONFIG_PATH=
NEMO_GUARDRAILS_SERVER_URL=
NEMO_GUARDRAILS_API_KEY=
GUARDRAILS_FAIL_CLOSED=true
GUARDRAILS_RECORD_EVALUATIONS=true

# Product prototype business-rule guardrails
DEFAULT_INVOICE_AMOUNT_USD=8500
DEFAULT_SPEND_CAP_USD=1150
DEFAULT_MARGIN_FLOOR_PERCENT=50
REQUIRE_HUMAN_APPROVAL_ABOVE_USD=1000
ENABLE_LIVE_PROOF=false
